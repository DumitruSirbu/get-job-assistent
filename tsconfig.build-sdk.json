{
    "compilerOptions": {
        "target": "ES2022",
        "lib": ["ES2022"],
        "outDir": "lib/sdk/dist",
        "strict": true,
        "strictPropertyInitialization": false,
        "useUnknownInCatchVariables": false,
        "skipLibCheck": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "esModuleInterop": true,
        "allowSyntheticDefaultImports": true,
        "sourceMap": true,
        "removeComments": true,
        "declaration": false
    },
    "include": ["./lib/sdk/**/*"],
    "exclude": ["./lib/sdk/dist"]
}
