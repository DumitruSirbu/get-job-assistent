##################### COMMON #####################
PORT=3000
NODE_ENV=development
SERVICE_NAME=get-job-assistent
HTTPLOG_DISABLED=false
##################################################

########################### APIFY ###########################
# Get from https://console.apify.com/settings/integrations
APIFY_TOKEN=your_apify_token_here
#############################################################

########################### REDIS ###########################
# Local Nest (npm run start): use localhost as host
# Docker Compose: compose overrides REDIS_HOST to the service name `redis`
REDIS_HOST=localhost
REDIS_PORT=6379
#############################################################

################################ POSTGRES ################################
# Local Nest (npm run start): use localhost as host, e.g.:
# POSTGRES_URL=postgres://app:app@localhost:5432/getjob
#
# Docker Compose: compose sets POSTGRES_URL for the app service (host must be
# the service name `postgres`, not localhost). These vars also configure the DB
# container and must match the user/password/db in your URL.
#
# Important: the Postgres Docker *image major version* must match the major
# version that created your persisted database files in the Docker volume. If
# you see "database files are incompatible with server", either pin Postgres
# back to the older major (recommended for keeping the same data directory) or
# dump/restore into a fresh volume on the newer major.
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=getjob
POSTGRES_URL=postgres://app:app@localhost:5432/getjob
##########################################################################

########################### OLLAMA ###########################
# Local Ollama instance - install from https://ollama.com
# Run: ollama pull gemma4
#
# Local Nest (npm run start): use localhost
# Docker Compose: compose overrides OLLAMA_HOST to host.docker.internal
#                 so the container can reach Ollama on the host machine
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=gemma4
#############################################################

########################### ANTHROPIC ###########################
# Required only when SCORING_PROVIDER=anthropic.
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
#################################################################

########################### SCORING ###########################
# Selects which LLM provider runs job scoring: ollama | anthropic
# Defaults to ollama. ScorerModel rows are keyed by provider+model, so
# switching providers creates new rows and re-scores jobs against them.
SCORING_PROVIDER=ollama
###############################################################

########################### JWT ###########################
# Use strong random secrets in production (e.g. openssl rand -hex 64)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
###########################################################

########################### DASHBOARD ###########################
DASHBOARD_URL=http://localhost:3001
#############################################################