##################### COMMON #####################
PORT=3000
NODE_ENV=development
SERVICE_NAME=get-job-assistent
HTTPLOG_DISABLED=false
##################################################

########################### APIFY ###########################
# Get from https://console.apify.com/settings/integrations
APIFY_TOKEN=your_apify_token_here
#############################################################

################################ POSTGRES ################################
# Local Nest (npm run start): use localhost as host, e.g.:
# POSTGRES_URL=postgres://app:app@localhost:5432/getjob
#
# Docker Compose: compose sets POSTGRES_URL for the app service (host must be
# the service name `postgres`, not localhost). These vars also configure the DB
# container and must match the user/password/db in your URL.
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=getjob
POSTGRES_URL=postgres://app:app@localhost:5432/getjob
##########################################################################
